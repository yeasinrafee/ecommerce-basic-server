model ProductCategory {
  id        String                 @id @default(uuid())
  name      String                 @unique
  slug      String                 @unique
  createdAt DateTime               @default(now())
  updatedAt DateTime               @updatedAt
  products  CategoriesOnProducts[]
}

model BlogCategory {
  id        String                 @id @default(uuid())
  name      String                 @unique
  slug      String                 @unique
  createdAt DateTime               @default(now())
  updatedAt DateTime               @updatedAt
}