model Shipping {
    id                        String   @id @default(uuid())
    minimumFreeShippingAmount Float
    tax                       Float
    defaultShippingCharge     Float
    maximumWeight             Float?
    maximumVolume             Float?
    length                    Float?
    width                     Float?
    height                    Float?
    chargePerWeight           Float?
    chargePerVolume           Float?
    createdAt                 DateTime @default(now())
    updatedAt                 DateTime @updatedAt
}
