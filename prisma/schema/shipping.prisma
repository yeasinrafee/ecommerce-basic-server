model Shipping {
    id                        String   @id @default(uuid())
    minimumFreeShippingAmount Float
    tax                       Float
    defaultShippingCharge     Float
    maximumWeight             Float?
    maximumVolume             Float?
    chargePerWeight           Float?
    chargePerVolume           Float?
    createdAt                 DateTime @default(now())
    updatedAt                 DateTime @updatedAt
}
